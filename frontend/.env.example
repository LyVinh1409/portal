# Frontend environment example
# Public API URL used by the Next.js client
NEXT_PUBLIC_API_URL=http://localhost:8080

# MinIO public settings (if used by frontend)
NEXT_PUBLIC_MINIO_ENDPOINT=http://localhost:9000
NEXT_PUBLIC_MINIO_BUCKET=cms-bucket
NEXT_PUBLIC_MINIO_ACCESS_KEY=minioadmin
NEXT_PUBLIC_MINIO_SECRET_KEY=minioadmin

# Other frontend-specific flags
NEXT_PUBLIC_FEATURE_FLAGS=
